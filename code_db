Table User {
  id integer [pk, increment]
  login varchar(50) [not null, unique]
  registered_at timestamp [not null, default: `now()`]
}

Table Post {
  id integer [pk, increment]
  user_id integer [not null, ref: > User.id]
  content text [not null]
  created_at timestamp [not null, default: `now()`]
}

Table Reaction {
  id integer [pk, increment]
  user_id integer [not null, ref: > User.id]
  post_id integer [not null, ref: > Post.id]
  type varchar(20) [not null]
  content text
}

Table Subscription {
  id integer [pk, increment]
  follower_id integer [not null, ref: > User.id]
  followee_id integer [not null, ref: > User.id]
}

Table Topic {
  id integer [pk, increment]
  name varchar(50) [not null, unique]
  description text
}

Table Post_Topic {
  post_id integer [ref: > Post.id]
  topic_id integer [ref: > Topic.id]
}

Table Keyword {
  id integer [pk, increment]
  word varchar(100) [not null, unique]
  topic_id integer [ref: > Topic.id]
}
